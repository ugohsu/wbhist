# Flask セッション署名用キー
# 生成: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# コンテナが作るファイルのオーナーをホストユーザーに合わせる
# 確認: id -u  /  id -g
APP_UID=1000
APP_GID=1000

# workbox の sync スクリプトが sessions.db を書き出すホスト上のディレクトリ
SQLITE_DIR=/home/<user>/claude-logs

# Phase 2 用（git 管理後に設定）
# WORKSPACE_DIR=/home/<user>/projects
