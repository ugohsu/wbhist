# Flask セッション署名用キー
# 生成: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# ログイン画面で要求する共有パスワード（未設定だとログイン不可になるので必ず設定する）
APP_PASSWORD=change-this-to-a-shared-password

# コンテナが作るファイルのオーナーをホストユーザーに合わせる
# 確認: id -u  /  id -g
APP_UID=1000
APP_GID=1000

# workbox の sync スクリプトが sessions.db を書き出すホスト上のディレクトリ
SQLITE_DIR=/home/<user>/claude-logs

# wbhist 自身の設定（プロジェクトごとの GitHub リポジトリ連携など）を保存する
# 書き込み可能なディレクトリ。事前に APP_UID/APP_GID で書き込めるように作成しておく
# 例: mkdir -p ~/wbhist-data
APP_DATA_DIR=/home/<user>/wbhist-data

# Phase 2 用（git 管理後に設定）
# WORKSPACE_DIR=/home/<user>/projects
